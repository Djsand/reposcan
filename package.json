{
  "name": "github-explode",
  "version": "0.1.0",
  "description": "The Codebase Doctor — scan any GitHub repo and get a full health report with scores, time bombs, and fixes",
  "type": "module",
  "bin": {
    "github-explode": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "codebase",
    "health",
    "analysis",
    "code-quality",
    "security",
    "time-bombs",
    "ai",
    "vibe-coding",
    "technical-debt",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18"
  }
}
